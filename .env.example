# ---------------------------------------------------------------------------
# Healthcare Q&A Agent — environment configuration
# Copy this file to `.env` and fill in the values you need:
#     cp .env.example .env
# The agent runs with only ONE provider key set. Anthropic is the default.
# ---------------------------------------------------------------------------

# --- LLM provider selection ---
# One of: anthropic | openai | mock
# "mock" runs the full agent loop deterministically with NO network/API key,
# which is handy for CI, offline demos, and grading the plumbing.
LLM_PROVIDER=anthropic

# --- Anthropic (default provider) ---
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
ANTHROPIC_MODEL=claude-opus-4-8

# --- OpenAI (fallback provider) ---
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
OPENAI_MODEL=gpt-4o

# --- Generation settings ---
LLM_TEMPERATURE=0.1
LLM_MAX_TOKENS=1500
LLM_TIMEOUT_SECONDS=45
LLM_MAX_RETRIES=3

# --- Agent settings ---
AGENT_MAX_STEPS=6
# NCBI recommends identifying your tool + contact email for the PubMed E-utilities.
# Optional, but improves rate limits. An NCBI_API_KEY (if you have one) raises the
# rate limit from 3 to 10 requests/sec.
NCBI_TOOL=healthcare-qa-agent
NCBI_EMAIL=you@example.com
NCBI_API_KEY=

# --- Logging ---
# DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
